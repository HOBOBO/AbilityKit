<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\..\..\Unity\Packages\com.abilitykit.protocol\Runtime\**\*.cs"
             Link="Protocol\%(RecursiveDir)%(Filename)%(Extension)" />
